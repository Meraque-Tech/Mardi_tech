FROM nvcr.io/nvidia/l4t-base:r32.7.1

ENV DEBIAN_FRONTEND=noninteractive
ENV CUDA_HOME=/usr/local/cuda
ENV CUDA_TOOLKIT_ROOT_DIR=/usr/local/cuda
ENV OPENBLAS_CORETYPE=ARMV8

RUN apt-get update && apt-get install -y \
    git \
    build-essential \
    cmake \
    wget \
    unzip \
    python3 \
    python3-pip \
    libopencv-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Copy TensorRT headers and libs from the Jetson host (already installed via JetPack)
# Run on host to find paths:
#   find /usr -name "NvInfer.h"              -> usually /usr/include/aarch64-linux-gnu/
#   find /usr -name "libnvinfer.so*"         -> usually /usr/lib/aarch64-linux-gnu/
COPY trt_include/ /usr/include/aarch64-linux-gnu/
COPY trt_lib/     /usr/lib/aarch64-linux-gnu/

RUN ln -sf /usr/local/cuda-10.2 /usr/local/cuda

WORKDIR /workspace

RUN git clone --depth=1 \
    https://github.com/wang-xinyu/tensorrtx.git

WORKDIR /workspace/tensorrtx/yolov8

# Fix Jetson paths
RUN sed -i 's/x86_64-linux-gnu/aarch64-linux-gnu/g' CMakeLists.txt || true

RUN mkdir build && cd build && \
    cmake .. \
    -DCMAKE_BUILD_TYPE=Release \
    -DCUDA_TOOLKIT_ROOT_DIR=/usr/local/cuda-10.2 \
    -DCMAKE_INCLUDE_PATH=/usr/include/aarch64-linux-gnu && \
    make -j4

CMD ["/bin/bash"]
