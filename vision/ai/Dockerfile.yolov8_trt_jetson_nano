# YoloV8 TensorRT 8 — Jetson Nano (JetPack 4.6, L4T r32.7.1)
# Source: https://github.com/Qengineering/YoloV8-TensorRT-Jetson_Nano/tree/tensorrt8
FROM nvcr.io/nvidia/l4t-tensorrt:r8.2.1-runtime
ARG DEBIAN_FRONTEND=noninteractive

SHELL ["/bin/bash", "-c"]

ENV OPENBLAS_CORETYPE=ARMV8
ENV CUDA_HOME=/usr/local/cuda-10.2
ENV PATH=${CUDA_HOME}/bin:${PATH}
ENV LD_LIBRARY_PATH=${CUDA_HOME}/targets/aarch64-linux/lib:${LD_LIBRARY_PATH}

WORKDIR /yolov8_ws

# Install build deps
RUN apt-get update && apt-get install -y \
        build-essential \
        git \
        libopencv-dev \
        python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Create unversioned libcudart.so symlink — CMake FindCUDA requires it; only .so.10.2 exists in runtime image
RUN ln -sf ${CUDA_HOME}/targets/aarch64-linux/lib/libcudart.so.10.2 \
           ${CUDA_HOME}/targets/aarch64-linux/lib/libcudart.so

# Upgrade CMake — 3.10 (Ubuntu 18.04 default) has FindCUDA bugs on aarch64
RUN pip3 install --upgrade cmake

COPY ./YoloV8-TensorRT-Jetson_Nano src

# Build
RUN mkdir -p src/build \
    && cd src/build \
    && cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCUDA_TOOLKIT_ROOT_DIR=${CUDA_HOME} \
    && make -j$(nproc)

# Copy binary to workspace root
RUN cp src/build/YoloV8rt /yolov8_ws/YoloV8rt

# Models dir — mount your .engine file here at runtime
RUN mkdir -p /yolov8_ws/models

CMD ["bash"]
