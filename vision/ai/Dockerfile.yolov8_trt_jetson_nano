# Jetson Nano — JetPack 4.6.1 (L4T r32.7.1), CUDA 10.2, OpenCV 4.1.1
FROM nvcr.io/nvidia/l4t-base:r32.7.1

ENV DEBIAN_FRONTEND=noninteractive
ENV CUDA_HOME=/usr/local/cuda
ENV CUDA_TOOLKIT_ROOT_DIR=/usr/local/cuda
ENV OPENBLAS_CORETYPE=ARMV8

RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    wget \
    unzip \
    python3 \
    python3-pip \
    libopencv-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# TensorRT headers and libs copied from the Jetson host (installed via JetPack).
# On the host, locate them with:
#   find /usr -name "NvInfer.h"       -> /usr/include/aarch64-linux-gnu/
#   find /usr -name "libnvinfer.so*"  -> /usr/lib/aarch64-linux-gnu/
# Then run:  ./build_yolov8_trt_nano.sh   which calls this Dockerfile via docker build context.
COPY trt_include/ /usr/include/aarch64-linux-gnu/
COPY trt_lib/     /usr/lib/aarch64-linux-gnu/

RUN ln -sf /usr/local/cuda-10.2 /usr/local/cuda

# Copy local yolov8 C++ source (your package, not tensorrtx)
WORKDIR /workspace/yolov8
COPY yolov8/ .

RUN mkdir -p build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCUDA_TOOLKIT_ROOT_DIR=/usr/local/cuda-10.2 \
    && make -j$(nproc)

# Binaries land in /workspace/yolov8/build/
CMD ["/bin/bash"]
