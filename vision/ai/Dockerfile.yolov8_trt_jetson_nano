# Jetson Nano — JetPack 4.6.1, CUDA 10.2, TensorRT 8.2.1
FROM nvcr.io/nvidia/l4t-tensorrt:r8.2.1-runtime

ENV DEBIAN_FRONTEND=noninteractive
ENV CUDA_HOME=/usr/local/cuda
ENV CUDA_TOOLKIT_ROOT_DIR=/usr/local/cuda
ENV OPENBLAS_CORETYPE=ARMV8

# Add JetPack 4.6.x apt repo (Jetson Nano = Tegra210/t210, L4T r32.7)
RUN echo "deb https://repo.download.nvidia.com/jetson/common r32.7 main" \
        > /etc/apt/sources.list.d/nvidia-l4t-apt-source.list && \
    echo "deb https://repo.download.nvidia.com/jetson/t210 r32.7 main" \
        >> /etc/apt/sources.list.d/nvidia-l4t-apt-source.list && \
    wget -qO - https://repo.download.nvidia.com/jetson/jetson-ota-public.asc \
        | apt-key add -

RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    wget \
    unzip \
    pkg-config \
    libopencv-dev \
    libnvinfer-dev \
    libnvonnxparsers-dev \
    libnvparsers-dev \
    libnvinfer-plugin-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy local yolov8 C++ source (your package, not tensorrtx)
WORKDIR /workspace/yolov8
COPY yolov8/ .

RUN mkdir -p build && cd build && \
    cmake .. \
    && make -j$(nproc)

# Binaries land in /workspace/yolov8/build/
CMD ["/bin/bash"]
