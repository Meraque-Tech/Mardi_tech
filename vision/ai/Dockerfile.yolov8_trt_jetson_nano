# Jetson Nano — JetPack 4.6.1 (L4T r32.7.1)
# l4t-ml already ships: CUDA 10.2 + TensorRT 8.x + OpenCV 4.x + Python3
# No manual header/lib copying needed.
FROM dustynv/ros:humble-ros-core-l4t-r32.7.1

ENV DEBIAN_FRONTEND=noninteractive
ENV CUDA_HOME=/usr/local/cuda
ENV CUDA_TOOLKIT_ROOT_DIR=/usr/local/cuda
ENV OPENBLAS_CORETYPE=ARMV8

RUN rm -f /etc/apt/sources.list.d/ros2.list \
    && apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    wget \
    unzip \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Copy local yolov8 C++ source (your package, not tensorrtx)
WORKDIR /workspace/yolov8
COPY yolov8/ .

RUN mkdir -p build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCUDA_TOOLKIT_ROOT_DIR=/usr/local/cuda-10.2 \
    && make -j$(nproc)

# Binaries land in /workspace/yolov8/build/
CMD ["/bin/bash"]
